# paperlaiss — Secrets/Config (NICHT committen; echte Werte hier eintragen).
PAPERLESS_TOKEN=<paperless-api-token-eines-users>
MISTRAL_KEY=<mistral-api-key>

# Panel-Schutz (optional): leer = offen (dann Reverse-Proxy/TinyAuth/OIDC davor).
PANEL_TOKEN=

# Ingest-API: ein Token je Eingang → Quelle-Tag (räumlich oder nach Person benennen).
INGEST_TOKENS={"geheim-scanner-buero":"Scan Büro","geheim-scanner-werkstatt":"Scan Werkstatt"}
